# ===========================================
# Scribbly Backend - Environment Variables
# Copy this to .env and fill in values
# NEVER commit .env to version control
# ===========================================

# ---------------------
# Application
# ---------------------
APP_NAME=Scribbly
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=local

# ---------------------
# API
# ---------------------
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------
# Database
# ---------------------
DATABASE_URL=postgresql+asyncpg://artuser:artpass@localhost:5432/scribbly

# ---------------------
# Redis
# ---------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------
# S3 / MinIO Storage
# ---------------------
S3_BUCKET=scribbly-dev
S3_ENDPOINT=http://localhost:9000
S3_KEY=minioadmin
S3_SECRET=minioadmin
S3_REGION=us-east-1

# ---------------------
# Authentication
# ---------------------
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------
# AI Engine
# ---------------------
MODEL_PATH=./ai-engine/models
GPU_ENABLED=false
INFERENCE_TIMEOUT=120

# ---------------------
# Rate Limiting
# ---------------------
RATE_LIMIT_FREE_TIER=10
RATE_LIMIT_WINDOW_SECONDS=86400

# ---------------------
# Logging
# ---------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
