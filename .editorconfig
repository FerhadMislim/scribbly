# ===========================================
# Scribbly - .editorconfig
# Consistent formatting across editors
# ===========================================
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown
[*.md]
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON
[*.json]
indent_style = space
indent_size = 2

# Python
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# JavaScript / TypeScript
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# CSS / SCSS
[*.{css,scss,sass}]
indent_style = space
indent_size = 2

# Swift
[*.swift]
indent_style = space
indent_size = 4

# Dockerfile
[Dockerfile]
indent_style = space
indent_size = 4

# Makefile
[Makefile]
indent_style = tab

# TOML
[*.toml]
indent_style = space
indent_size = 4
